# Section 4 — Analytics Dashboard (Time Management Insights)
# --------------------------------------------------------
st.header("📊 Scheduling Analytics Dashboard")

def compute_analytics(service):
    events = get_upcoming_events(service, max_results=100)
    summary_data = {}
    total_hours = 0
    for e in events:
        if "dateTime" in e["start"] and "dateTime" in e["end"]:
            start = datetime.datetime.fromisoformat(e["start"]["dateTime"].replace("Z", "+00:00"))
            end = datetime.datetime.fromisoformat(e["end"]["dateTime"].replace("Z", "+00:00"))
            dur = (end - start).seconds / 3600
            cat = "Study" if "study" in e["summary"].lower() else "Classes" if "class" in e["summary"].lower() else "Others"
            summary_data[cat] = summary_data.get(cat, 0) + dur
            total_hours += dur
    return summary_data, total_hours

if st.button("📈 Generate Analytics"):
    summary_data, total_hours = compute_analytics(service)
    if total_hours > 0:
        st.success(f"Total Scheduled Time: {total_hours:.1f} hours upcoming")
        df_summary = pd.DataFrame(list(summary_data.items()), columns=["Category", "Hours"])
        st.bar_chart(df_summary.set_index("Category"))
    else:
        st.info("No future events found in your calendar.")

# --------------------------------------------------------
# Section 5 — Intelligent Rescheduling
# --------------------------------------------------------
st.header("🔁 Intelligent Rescheduling Assistant")

event_name = st.text_input("Event to Reschedule (exact name from calendar)")
shift_days = st.number_input("Shift by days (+ve to postpone)", value=1, step=1)
if st.button("Reschedule Event"):
    events = get_upcoming_events(service, max_results=50)
    found = False
    for e in events:
        if e["summary"].lower() == event_name.lower() and "dateTime" in e["start"]:
            found = True
            start = datetime.datetime.fromisoformat(e["start"]["dateTime"].replace("Z", "+00:00")) + datetime.timedelta(days=int(shift_days))
            end = datetime.datetime.fromisoformat(e["end"]["dateTime"].replace("Z", "+00:00")) + datetime.timedelta(days=int(shift_days))
            service.events().update(
                calendarId="primary",
                eventId=e["id"],
                body={**e, "start": {"dateTime": start.isoformat(), "timeZone": "Asia/Kolkata"},
                         "end": {"dateTime": end.isoformat(), "timeZone": "Asia/Kolkata"}},
            ).execute()
            st.success(f"✅ Rescheduled '{event_name}' by {shift_days} day(s).")
            break
    if not found:
        st.error("Event not found. Please check spelling or event existence.")

