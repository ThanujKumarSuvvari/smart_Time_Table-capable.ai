st.header("📤 Export Functionality")

def export_to_csv():
    events = get_upcoming_events(service, max_results=50)
    rows = []
    for e in events:
        if "dateTime" in e["start"]:
            start = e["start"]["dateTime"]
            end = e["end"]["dateTime"]
            rows.append([e["summary"], start, end])
    df = pd.DataFrame(rows, columns=["Event", "Start", "End"])
    df.to_csv("calendar_export.csv", index=False)
    return df

if st.button("Export Calendar Events"):
    df_export = export_to_csv()
    st.dataframe(df_export)
    st.success("Exported upcoming events → calendar_export.csv")

