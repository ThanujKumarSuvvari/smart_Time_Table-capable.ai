import subprocess, sys

def install(pkg):
    subprocess.check_call([sys.executable, '-m', 'pip', 'install', pkg, '-q'])

packages = ['ortools', 'plotly', 'pandas', 'tabulate', 'kaleido']

print('Installing packages...')
for p in packages:
    install(p)
    print(f'  OK: {p}')

print('\nAll packages installed successfully!')
